# Optional. Route App Store + Google Play requests through a proxy so they work
# from a cloud host (Vercel, etc.), whose datacenter IPs the stores throttle.
#
# Use any HTTP/HTTPS proxy that supports HTTPS access. Scraping-API proxy
# endpoints (ScraperAPI, ScrapingBee, Zyte, Bright Data, Smartproxy, …) work
# well and several have free tiers.
#
# Leave unset for a direct connection (fine when running from a residential IP).
# SCRAPER_PROXY_URL=http://USERNAME:PASSWORD@proxy-host:PORT

# Set to true ONLY if your proxy intercepts TLS and presents its own certificate
# (e.g. ScraperAPI "proxy mode"). It skips cert verification on the proxied
# connection. Not needed for plain CONNECT-tunnelling residential proxies.
# SCRAPER_PROXY_INSECURE=true

# Required for the "Analyze reviews" feature (/analyze). Your Anthropic API key —
# get one at https://console.anthropic.com. Used server-side to cluster reviews
# (Claude Opus 4.8) and generate the build-spec prompt.
# ANTHROPIC_API_KEY=sk-ant-...

# Required for the Projects SaaS (accounts + saved projects). From your Supabase
# project: Settings → API. The publishable/anon key is safe to expose (it ships
# to the browser and is gated by Row Level Security). Add BOTH to Vercel too.
# Without these, the app still runs the legacy scraper + /analyze; the Projects
# area is disabled.
# NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_...
